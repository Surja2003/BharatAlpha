# Copy this file to .env and fill in your values.

# ─── APP ────────────────────────────────────────────────────────────────────
SECRET_KEY=generate-a-random-64-char-string-here
ENVIRONMENT=development
DEBUG=false

# ─── DATABASE ───────────────────────────────────────────────────────────────
# Local Postgres:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/bharatalpha
# Supabase (free tier):
# DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxx.supabase.co:5432/postgres

# ─── REDIS ──────────────────────────────────────────────────────────────────
# Local Redis:
REDIS_URL=redis://127.0.0.1:6379/0
# Upstash (free tier):
# REDIS_URL=rediss://default:password@xxx.upstash.io:6380

# ─── IIFL SECURITIES (IIFL Capital / TTBlaze) ───────────────────────────────
# Get your API credentials from: https://ttblaze.iifl.com/apiuser/login
IIFL_API_KEY=your_app_key_here

# Long App Secret Key from IIFL developer portal (NOT used for login directly)
IIFL_SECRET_KEY=your_long_app_secret_here

# Your TTBlaze login password (short, <=12 chars) sent as `secretKey` in login body
# This is the same password you use to log into IIFL Capital / TTBlaze web portal
IIFL_TTBLAZE_SECRET_KEY=your_login_password

# Your IIFL demat client ID / user ID
IIFL_CLIENT_CODE=your_client_code

# Optional: IIFL 2FA PIN (if required by your account)
IIFL_2PIN=

# TTBlaze REST & WebSocket endpoints (IIFL Capital)
IIFL_BASE_URL=https://ttblaze.iifl.com
IIFL_WS_URL=wss://ttblaze.iifl.com/feed

# Optional: override API paths if your account uses different routes
IIFL_AUTH_PATH=/apimarketdata/auth/login
IIFL_QUOTE_PATH=/apimarketdata/marketdata/quote
IIFL_HISTORY_PATH=/apimarketdata/instruments/history/
IIFL_MASTER_PATH=/apimarketdata/instruments/master/

# ─── DATA SOURCES ───────────────────────────────────────────────────────────
PRICE_SOURCE=iifl
FUNDAMENTAL_SOURCE=screener_scrape
NEWS_SOURCE=rss_free
MF_SOURCE=amfi_free
FNO_SOURCE=iifl

# ─── LIVE TRACKING ──────────────────────────────────────────────────────────
# Comma-separated NSE symbols for WebSocket publishing & Redis polling
TRACKED_SYMBOLS=RELIANCE,SBIN,TCS,INFY,HDFCBANK,ICICIBANK,WIPRO,BAJFINANCE,NTPC,LT,ITC,MARUTI,TATAMOTORS,AXISBANK,HINDUNILVR

# ─── LATENCY BUDGETS (seconds) ──────────────────────────────────────────────
LIVE_QUOTE_TIMEOUT_S=0.9
LIVE_QUOTE_BUDGET_S=1.2
BULK_QUOTES_TIMEOUT_S=1.2
BULK_QUOTES_BUDGET_S=1.6
HISTORY_TIMEOUT_S=2.5
HISTORY_BUDGET_S=3.0

# ─── HTTP CLIENT TUNING (httpx) ────────────────────────────────────────────
HTTPX_TIMEOUT_S=20.0
HTTPX_CONNECT_TIMEOUT_S=10.0
HTTPX_MAX_CONNECTIONS=100
HTTPX_MAX_KEEPALIVE_CONNECTIONS=20
HTTPX_KEEPALIVE_EXPIRY_S=30.0
HTTPX_HTTP2=true

# ─── REDIS PRICE CACHE ──────────────────────────────────────────────────────
REDIS_TICK_MAX_AGE_S=8.0
REDIS_TICK_DIAG_SAMPLE_N=10

# ─── DEV / TEST SWITCHES ────────────────────────────────────────────────────
# Set to true only in local dev to allow fallback synthetic OHLCV data
ALLOW_SYNTHETIC_HISTORY=false
